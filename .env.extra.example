# OpenClaw 额外环境变量配置示例
# 使用方法：python3 deploy-docker.py -e .env.extra

#===============================================================================
# 应用配置
#===============================================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 调试模式 (true/false)
DEBUG=false

# 应用环境 (development, staging, production)
APP_ENV=production

#===============================================================================
# 服务器配置
#===============================================================================

# 最大工作进程数
MAX_WORKERS=4

# 最大连接数
MAX_CONNECTIONS=100

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

#===============================================================================
# 缓存配置
#===============================================================================

# 缓存 TTL（秒）
CACHE_TTL=3600

# 缓存类型 (memory, redis)
CACHE_TYPE=memory

#===============================================================================
# 安全配置
#===============================================================================

# JWT 密钥（生产环境请修改）
JWT_SECRET=your-secret-key-change-in-production

# Session 密钥
SESSION_SECRET=your-session-secret

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=https://example.com,https://api.example.com

#===============================================================================
# 功能开关
#===============================================================================

# 启用 API 文档 (true/false)
ENABLE_SWAGGER=true

# 启用性能分析 (true/false)
ENABLE_PROFILING=false

# 启用速率限制 (true/false)
ENABLE_RATE_LIMIT=true

# 速率限制（请求数/分钟）
RATE_LIMIT_PER_MINUTE=60

#===============================================================================
# 外部服务配置
#===============================================================================

# Redis 连接（如使用）
# REDIS_URL=redis://localhost:6379/0

# 邮件服务配置
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=password

# 对象存储配置
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=my-bucket
# S3_ACCESS_KEY=access-key
# S3_SECRET_KEY=secret-key

#===============================================================================
# 监控配置
#===============================================================================

# 启用 Prometheus 指标 (true/false)
ENABLE_METRICS=false

# Prometheus 端口
METRICS_PORT=9090

# 启用健康检查端点 (true/false)
ENABLE_HEALTH_CHECK=true

#===============================================================================
# 数据库连接池配置
#===============================================================================

# 最小连接数
DB_POOL_MIN=2

# 最大连接数
DB_POOL_MAX=10

# 连接超时（秒）
DB_CONNECT_TIMEOUT=5

# 空闲连接超时（秒）
DB_IDLE_TIMEOUT=30

# ===============================================================================
# OpenClaw IT-Team Workspace Git Ignore 配置
# 
# 原则：GitHub 只发布系统代码和必要文档，不包含敏感信息和开发过程文件
# ===============================================================================

# ---------------------------------------------------------------------------
# 🔐 敏感信息和安全密钥（绝对禁止）
# ---------------------------------------------------------------------------
# SSH 密钥
github_deploy_key
*.key
*.pem
*.ppk
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
!.gitkeep

# 数据库凭证
config/database.local.json
config/database.*.json
!config/database.example.json

# API 密钥和令牌
*.env.local
*.env.*.local
secrets.json
credentials.json
*.credentials
*.secret

# ---------------------------------------------------------------------------
# 📝 开发过程文档（不发布）
# ---------------------------------------------------------------------------
# 开发进度报告
*_PROGRESS.md
DEV_*.md
TODO.md
CHANGELOG_LOCAL.md

# 测试报告
*_TEST_REPORT.md
*_CHECK_REPORT.md
test-results/
coverage/

# 临时文档
*.bak.md
*.draft.md
*.tmp.md

# 会议记录
meetings/
notes/

# ---------------------------------------------------------------------------
# 🧪 测试文件（不发布）
# ---------------------------------------------------------------------------
# 测试脚本（除非是项目正式测试套件）
test_*.js
test_*.py
*_test.js
*_test.py
migrate_*.js
migrate_*.py
check_*.js
check_*.py

# 测试数据
test_data/
fixtures/
!tests/fixtures/

# ---------------------------------------------------------------------------
# 📦 Node.js / JavaScript 依赖
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ---------------------------------------------------------------------------
# 🛠️ 开发工具和 IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*

# ---------------------------------------------------------------------------
# 🏗️ 构建输出（由 CI/CD 生成）
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
*.log

# ---------------------------------------------------------------------------
# ⚙️ 环境变量和配置
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# 敏感配置（只保留示例）
config/secrets.json
*.key
*.pem
!.gitkeep

# ---------------------------------------------------------------------------
# 📜 日志文件
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# 🐍 Python
# ---------------------------------------------------------------------------
venv/
env/
.env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# ---------------------------------------------------------------------------
# 🐳 Docker
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml
docker-compose.local.yml

# ---------------------------------------------------------------------------
# 📊 数据库
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
database/*.local.sql
database/migrations/local/

# ---------------------------------------------------------------------------
# 📁 临时文件
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
*.old

# ---------------------------------------------------------------------------
# 📚 文档生成
# ---------------------------------------------------------------------------
docs/_build/
site/
public/
mkdocs.yml.local

# ---------------------------------------------------------------------------
# 🤖 OpenClaw 内部文件
# ---------------------------------------------------------------------------
.openclaw/
memory/
MEMORY.md
SOUL.md
USER.md
AGENTS.md
IDENTITY.md
HEARTBEAT.md
BOOTSTRAP.md

# ---------------------------------------------------------------------------
# 📋 其他
# ---------------------------------------------------------------------------
# 保留此文件本身
!.gitignore

# README 示例（如果有）
!README.example.md

# ===============================================================================
# OpenClaw IT-Team Workspace Git Ignore 配置
# ===============================================================================

# ---------------------------------------------------------------------------
# 敏感文件和安全密钥
# ---------------------------------------------------------------------------
github_deploy_key
*.key
*.pem
!.gitkeep

# ---------------------------------------------------------------------------
# Node.js / JavaScript 依赖
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ---------------------------------------------------------------------------
# 开发工具和 IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# 构建输出
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
*.log

# ---------------------------------------------------------------------------
# 环境变量和配置
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# 敏感配置（保留示例文件）
config/secrets.json
config/database.local.json
*.key
*.pem
!.gitkeep

# ---------------------------------------------------------------------------
# 日志文件
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# 测试和覆盖率
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
jest-results.json
test-results/

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ---------------------------------------------------------------------------
# 临时文件
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig

# ---------------------------------------------------------------------------
# 文档生成
# ---------------------------------------------------------------------------
docs/_build/
site/
public/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
venv/
env/
.env/
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# OpenClaw 内部文件
# ---------------------------------------------------------------------------
.openclaw/

# ---------------------------------------------------------------------------
# 其他
# ---------------------------------------------------------------------------
# 保留此文件本身
!.gitignore
